        if(userType == 'personal') {
            _html += '微博已开启品牌授权投放模式，如选择主体资质时显示无法投放，请先取得品牌授权文件，并联系平台客服。';
        } else if(userType == 'task') { // 提交时提示
            _html += '该任务中的主体资质对应品牌已开启授权投放，目前您尚未获得授权，不能进行投放。';

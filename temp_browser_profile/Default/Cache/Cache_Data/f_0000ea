            _html += '<div style="padding: 50px 30px 40px; text-align: center; color: #666666; font-size: 14px; line-height: 20px;">';
            _html += content;
            _html += '</div>';
        } else if (type == 3) { // 欠临近/逾期还款提示
            singleModeOptions = {
                okText: "确定"
            }
            closeBtn = 1;
            _html += '<div style="padding: 50px 30px 40px; text-align: left; color: #666666; font-size: 14px; line-height: 20px;">';
            _html += content;
            _html += '</div>';
        } else {
            return;
        }

        var SimpleDialog = FrequentlyUtils.CreateSimpleDialig({
            title: '通知',
            area: ["500px"],
            closeBtn: closeBtn,
            content: _html,
            _singleModeOptions: singleModeOptions,
            _ok: function() {
                cb && cb()

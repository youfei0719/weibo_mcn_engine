            _html += '<div class="center-aside-extend" style="display:none">'
            _html += '<div class="aside-extend-product extend-pick">';
            for (var i = 0, L = data.extend.length; i < L; i++) {
                var extend = data.extend[i];
                // console.log(extend)
                _html += '<p class="extend-product-tlt c64"><span class="product-tlt-wd">' + extend.title + '</span></p>';
                _html += '<div class="extend-product-wrap cf">';
                for (var j = 0, _L = extend.child.length; j < _L; j++) {
                    _html += '<div class="extend-product-list lf overflow-noellipsis">'
                    _html += '<a href="' + extend.child[j].url + '" class="c64 red-link-1">'
                    _html += '<img src="' + extend.child[j].imgurl + '" />'
                    _html += '<span class="product-list-wd">' + extend.child[j].name + '</span>'
                    _html += '</a></div>'
                };
                _html += '</div>';
            };
            _html += '</div></div></div>'
            _html += '<div class="aside-list-wrap ' + (_isActive ? "wrap-first" : '') + ' ">'
            for (var i = 0, L = data.child.length; i < L; i++) {
                _html += '<a class="aside-list-item ' + (data.child[i].active == 1 ? 'active' : '') + '" href="' + data.child[i].url + '">';
                _html += '<span>' + data.child[i].product_name + '</span>' + '</a>'
            };
            _html += '</div></div></div>';
            return _html;
        };

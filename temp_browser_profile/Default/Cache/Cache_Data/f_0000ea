    // 顶导同步站内信信息
    function topNavSyncMessageInfo() {
        // 获取未读数
        $.ajax({
            type: "GET",
            url: "/owner/innermessage/get_unread_list.html",
            dataType: "json",
            async:false,
            success: function(res){
                var data = res.data || {};
                if (data.is_new) {
                    // 有近24小时内未读新消息
                    $('.cms-handle-msg-wrap').find('.new-message-icon-new').show();
                    $('.cms-handle-msg-wrap').find('.new-message-count').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count-plus').hide();
                } else if (data.unread_count && data.unread_count.length > 1) {
                    // 未读数两位数及以上
                    $('.cms-handle-msg-wrap').find('.new-message-icon-new').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count-plus').html(data.unread_count).show();
                } else if (data.unread_count && data.unread_count != '0' && data.unread_count.length > 0) {
                    // 有未读消息
                    $('.cms-handle-msg-wrap').find('.new-message-icon-new').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count').html(data.unread_count).show();
                    $('.cms-handle-msg-wrap').find('.new-message-count-plus').html(data.unread_count).hide();
                } else {
                    $('.cms-handle-msg-wrap').find('.new-message-icon-new').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count').hide();
                    $('.cms-handle-msg-wrap').find('.new-message-count-plus').hide();
                }
            },
            error: function(xhr,status,error) {

            }
        })

        // 获取最新未读消息
        $.ajax({
            type: "POST",
            url: "/owner/innermessage/msg_list.html",
            dataType: "json",
            async:false,
            data: {
                type: 0, // 消息类型0全部1系统2订单3沟通
                status: 0, // 0全部1已读2未读
                search: '', // 搜索内容
                size: '3', // 每页条数
            },
            success: function(res){
                // 最多三条
                var length = res.data.data.length > 3 ? 3 : res.data.data.length;
                if (length > 0) {
                    var _html = '', item;
                    for (var i = 0; i < length; i++) {
                        item = res.data.data[i];
                        _html += '<a class="message-item" href="'+"/owner/Innermessage/totalMessage.html?id=" + item.id +'">'
                        _html +=     '<p class="message-title single-line-ellipsis">'+ item.title +'</p>'
                        _html +=     '<div class="message-content two-line-ellipsis">'+(item.sub_title || item.content) +'</div>'
                        _html += '</a>'
                    }

                    $('.new-message-list-p').find('.new-message-list').html(_html).show();
                    $('.new-message-list-p').find('.new-message-empty').hide();
                } else {
                    $('.new-message-list-p').find('.new-message-empty').show();
                    $('.new-message-list-p').find('.new-message-list').hide();
                }

            },
            error: function(xhr,status,error) {

            }
        })
    }

    $(function() {

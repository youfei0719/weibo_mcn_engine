    if (location.pathname != '/owner/index/index.html' && !location.pathname.includes('/owner/index/index/ownerid')) {
        showPaymentDialog()
    }
    function showPaymentDialog (cb) {
        if (delay_locked_adver_notice) { // 欠款广告主
            showDebtDialog(1, delay_locked_adver_notice, cb);
        } else if (delay_locked_agent_notice) { // 欠款代理商下未欠款广告主

<script type="text/javascript">
    // 选号车悬浮
    // hover状态下 更新的新元素会不断的触发mouseenter事件
    var mouseenterKey = true
    $('.cms-shopping-cart').mouseenter(cartMouseenter);
    $('.cms-shopping-cart').mouseleave(function (){ mouseenterKey = true});
    function cartMouseenter(){
        if(!mouseenterKey) return;
        var _li = ''
        var platformArr = [
            '/Public/owner/images/newOwner/plat/icon_weibo.png',
            '/Public/owner/images/newOwner/plat/icon_wechat.png',
            '/Public/owner/images/newOwner/plat/icon_douyin.png',
            '/Public/owner/images/newOwner/plat/icon_redbook.png',
            '/Public/owner/images/newOwner/plat/icon_ks.png',
            '/Public/owner/images/newOwner/plat/icon_bilibili.png',
        ]
        $('.cms-shopping-ul').show()
        $('.cms-shopping-none').hide()
        $('.cms-shopping-total').show()
        getAllPlatformListFn()
        $.ajax({
            type: "get",
            url: shoppingcarGetList,
            dataType: "JSON",
            success: function (res) {
                if (res.code == 200 ) {
                    if(res.data.data.length > 0){
                        
                        $('.cms-shopping-count').html(res.data.count)
                        for(var i = 0; i < res.data.data.length; i++) {
                            var price = res.data.data[i].price == 0?'-':'￥'+res.data.data[i].price
                            var _avatar = res.data.data[i].platform == 1 ? "https://imgwb.apput.com/img_url?" + res.data.data[i].avatar : res.data.data[i].avatar;
                            _li += '<li class="cms-shopping-li">'+
                            '<div class="shopping-li-information">'+
                                '<div class="shopping-li-photo">'+
                                    '<img class="shopping-li-avatar" src="'+_avatar+'" >'+
                                    '<img class="shopping-li-platform" src="'+platformArr[+res.data.data[i].platform-1]+'" >'+
                                '</div>'+
                                '<div class="shopping-li-name text-hid">'+
                                    res.data.data[i].account_name
                                +'</div>'+
                            '</div>'+
                            '<div class="shopping-li-price">'+
                                '<span>'+price+'</span>'+
                                '<i platform="'+(+res.data.data[i].platform)+'" mediaid="'+res.data.data[i].mediaid+'" class="base-iconfont shopping-li-del">&#xe67d;</i>'+
                            '</div>'+
                        '</li>'
                        }
                        $('.cms-shopping-ul').html(_li)
                        
                        
                    }else{
                        $('.cms-shopping-ul').hide()
                        $('.cms-shopping-none').show()
                        $('.cms-shopping-total').hide()
                    }
                    mouseenterKey = false
                } else {
                    layer.msg(res.msg);
                }
               
            },
            error: function (res) {
                layer.msg('操作失败');
                // layer.close(_idx);
            }
        });
	}
    // 删除
    $(document).on("click",'.shopping-li-del',function (e){
        // debugger
        var delApi = [
            "/owner/newweibo/delShoppingcarAccount.html",
            "/owner/wechat/delShoppingcarAccount.html",
            "/owner/douyin/delShoppingcarAccount.html",
            "/owner/redbook/delShoppingcarAccount.html",
            "/owner/ks/delShoppingcarAccount.html",
            "/owner/bili/delShoppingcarAccount.html",
        ]
        var delName = [
            'weibo',
            'wechat',
            'douyin',
            'xhs',
            'ks',
            'bili',
        ]
        var dom = $(this)
        var mediaid = dom.attr('mediaid')
        var platform = dom.attr('platform')
        var $check = $("#check_" + mediaid);
        $.ajax({
            type: "post",
            url: delApi[+platform - 1],
            data:{mediaid:mediaid},
            dataType: "JSON",
            success: function (res) {
                if (res.code == 200 ) {
                    // debugger
                    // 重新渲染列表
                    mouseenterKey = true
                    // 选号车页面 悬浮框删除账号 更新选号车列表
                    typeof delNavAccount === 'function' && delNavAccount(delName[+platform - 1])
                    cartMouseenter()
                    $check.removeAttr("checked");
                } else {
                    layer.msg(res.msg);
                }
            },
        })
    })


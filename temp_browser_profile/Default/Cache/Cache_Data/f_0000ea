    function genSinaMakerExamineDialogContent(userType,msg) {
        var _label = ''
        if(new_order_process==1){
            _label = '项目'
        } else if(self_help==1||agent_label==5||agent_label==3){
            _label = '项目'
        } else if(need_brand_auth==1) {
            _label = '工作单'
        }
        var _html = "";

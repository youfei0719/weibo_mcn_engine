            _html += '该品牌已开启授权投放，目前您尚未获得授权，不能进行投放。';
        } else if (userType == 404) {
            _html += '该'+ _label +'无品牌信息，请重新创建项目或选择包含品牌信息的'+_label+'。';
        } else if (Number(userType) >= 50001 && Number(userType) <= 59999) {
            _html += (msg || "");
        } else {
            // _html += '该'+ _label +'对应品牌已开启授权投放，目前您尚未获得授权，不能进行投放。';
            _html += '该品牌已开启授权投放，目前您尚未获得授权，不能进行投放。';
        }
        return _html;

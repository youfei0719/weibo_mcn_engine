            // 点击一级菜单
            $('.aside-list-tlt').click(function () {
                var _this = $(this);
                if (_this.siblings(".aside-list-wrap").children().length === 0) {
                    if (!_this.hasClass("active")) {
                        _this.addClass('active').parents('.center-aside-list').siblings('.center-aside-list').each(function () {
                            $(this).find(".aside-list-tlt").removeClass("active");
                            $(this).find('.aside-list-wrap').slideUp().siblings(".aside-list-tlt").removeClass("isclose");
                        });
                    }
                } else {
                    var childWrap = _this.parents('.center-aside-list').find('.aside-list-wrap');
                    if (childWrap.css("display") === "none") {
                        childWrap.slideDown().parents('.center-aside-list').siblings('.center-aside-list').find('.aside-list-wrap').each(function () {
                            var _this2 = $(this);
                            _this2.slideUp(function () {

var FrequentlyUtils = {

    /**
     * 扩展layer弹窗
     *
     * 引入样式 common-dialog，定义了标题栏及底部按钮样式
     * options新增属性
     * {
     * ...
     * _singleModeOptions: [Boolean | String | Object: {okText, href, target}], 底部单个按钮
     * _doubleModeOptions: [Boolean | Object: {cancelText, okText, href, target}], 底部两个按钮
     * _cancel: [Function], 点击取消或右上角关闭，添加后后弹窗需手动关闭
     * _ok: [Function], 点击确定按钮回调，添加后后弹窗需手动关闭
     * ...
     * }
     *
     */
    showCustomDialog: function (options) {
        var _html = '', layerIndex;
        if (options._singleModeOptions) {
            _html += '<div class="common-dialog-has-btn">' + (options.content || '') + '</div>'

            _html += '<div class="common-dialog-btn-p">';
            if (typeof options._singleModeOptions === 'string') {
                _html += '<a class="common-dialog-btn large-btn active-btn" href="javascript:;">' + options._singleModeOptions + '</a>';
            } else if (Object.prototype.toString.call(options._singleModeOptions) === '[object Object]') {
                _html += '<a class="common-dialog-btn large-btn active-btn" href="' + (options._singleModeOptions.href || 'javascript:;') + '" target="' + (options._singleModeOptions.target || '_self') + '">' + (options._singleModeOptions.okText || '确定') + '</a>';
            } else {
                _html += '<a class="common-dialog-btn large-btn active-btn">确定</a>';
            }
            _html += '</div>';
        } else if (options._doubleModeOptions) {
            _html += '<div class="common-dialog-has-btn">' + (options.content || '') + '</div>'

            _html += '<div class="common-dialog-btn-p">';
            if (Object.prototype.toString.call(options._doubleModeOptions) === '[object Object]') {
                _html += '<a class="common-dialog-btn middle-btn default-btn" href="javascript:;">' + (options._doubleModeOptions.cancelText || '取消') + '</a>';
                _html += '<a class="common-dialog-btn middle-btn active-btn" href="' + (options._doubleModeOptions.href || 'javascript:;') + '" target="' + (options._doubleModeOptions.target || '_self') + '">' + (options._doubleModeOptions.okText || '确定') + '</a>';
            } else {
                _html += '<a class="common-dialog-btn middle-btn default-btn">取消</a>';
                _html += '<a class="common-dialog-btn middle-btn active-btn">确定</a>';
            }
            _html += '</div>';
        } else {
            _html += (options.content || '')
        };

        if (options._absolutHtml) {
            _html += (options._absolutHtml || '');
        }

        options.content = _html;
        options.skin = "common-dialog " + (options.skin || '');

        var cancelFun = options.cancel;
        options.cancel = function () {
            if (typeof options._cancel === 'function') {
                options._cancel.apply(this, arguments);
            } else if (cancelFun) {
                cancelFun.apply(this, arguments);
            } else {
                layer.close(layerIndex);
            }
        }

        var successFun = options.success;
        options.success = function () {
            $('.common-dialog-btn-p').find('.default-btn').click(function () {
                !options._cancel && layer.close(layerIndex);
                typeof options._cancel === 'function' && options._cancel.apply(this, arguments);
            })
            $('.common-dialog-btn-p').find('.active-btn').click(function () {
                !options._ok && layer.close(layerIndex);
                typeof options._ok === 'function' && options._ok.apply(this, arguments);
            })

            successFun && successFun.apply(this, arguments);
        }

        !options.type && (options.type = 1);
        layerIndex = layer.open(options);

        return layerIndex;
    },


                    _html += '<a class="frequent-simple-dialog-btn middle-btn active-btn" href="' + (options._doubleModeOptions.href || 'javascript:;') + '" target="' + (options._doubleModeOptions.target || '_self') + '">' + (options._doubleModeOptions.okText || '确定') + '</a>';

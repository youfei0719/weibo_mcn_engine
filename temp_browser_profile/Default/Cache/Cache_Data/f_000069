    // 获取文件
    /**
     * 获取本地文件
     * @param {Object} options
     * 支持配置项
     * {
     *  multiple: 'multiple', 是否支持多选
     *  maxLength: [Number], 最多可选个数
     *  maxLengthError: [String], 选择个数超限时错误提示
     *  maxSize: [Number], 最大支持文件大小，单位bit
     *  maxSizeError: [String], 选择文件大小超限时错误提示
     *  suffix: [String | Array], 支持的文件类型 'pdf,jpg' | ['pdf', 'jpg']
     *  suffixError: [String], 选择文件类型错误时提示
     *  success: [Function], 选择成功 返回files
     *  fail: [Function], 选择失败 返回Object 包含错误信息errorMsg及不支持文件的文件名nonsupportFiles
     * }
     *
     */
    selectFileFromFolder: function (options) {
        if (options && Object.prototype.toString.call(options) !== '[object Object]') {
            options.fail && options.fail.call(this, {
                errorMsg: "options需为对象"
            });
            return false;
        } else {
            options = options || {};
        }

        var inputNode = getInputNode(options);
        inputNode.click();

        function onChange(el) {
            if (el && el.target && el.target.files) {
                var fileList = el.target.files;
                var limitResult = limitPass(fileList);
                if (limitResult.status == 1) {
                    var argumentsArr = Array.prototype.slice.call(arguments);
                    argumentsArr.unshift(fileList);
                    options.success && options.success.apply(this, argumentsArr);
                } else {
                    options.fail && options.fail.call(this, limitResult);
                }
            } else {
                options.fail && options.fail.call(this, {
                    errorMsg: "文件选择失败"
                });
            }

            inputNode.removeEventListener('change', onChange);
            document.body.removeChild(inputNode);
            inputNode = null;
        }

        function limitPass(fileList) {
            var fileArr = Array.prototype.slice.call(fileList) // 文件列表
                , errorSuffixFile = '' // 不支持类型的文件
                , errorSizeFile = '' // 不支持大小的文件
                , limitResult = {
                    status: 1, // 1成功 2失败
                    errorMsg: "", // 错误信息
                    nonsupportFiles: "", // 不支持的文件名
                };

            // 限制文件类型数组
            var supportSuffixArr = [];
            if (options.suffix) {
                if (typeof options.suffix === 'string') {
                    var tempArr = options.suffix.split(',');
                    for (var k = 0; k < tempArr.length; k++) {
                        tempArr[k].trim() && supportSuffixArr.push(tempArr[k].trim().toLowerCase())
                    }
                } else if (Object.prototype.toString.call(options.suffix) === '[object Array]') {
                    for (var k = 0; k < options.suffix.length; k++) {
                        options.suffix[k].trim() && supportSuffixArr.push(options.suffix[k].trim().toLowerCase())
                    }
                } else {
                    supportSuffixArr = [];
                }
            }

            var i = 0, j = 0, fileItem = null, suffixIndex = 0, suffix = '';
            for (i = 0; i < fileArr.length; i++) {
                fileItem = fileArr[i];

                // 限制文件类型 生成不支持的类型
                if (options.suffix) {
                    suffixIndex = fileItem.name.lastIndexOf(".");
                    suffix = fileItem.name.substr(suffixIndex + 1).toLowerCase();
                    for (j = 0; j < supportSuffixArr.length; j++) {
                        if (supportSuffixArr[j] == suffix) {
                            break;
                        } else if (j === (supportSuffixArr.length - 1)) {
                            // 非允许类型
                            errorSuffixFile += (fileItem.name + ",")
                        }
                    }
                }

                // 限制文件大小
                if (options.maxSize && fileItem.size > options.maxSize) {
                    errorSizeFile += (fileItem.name + ",")
                }
            }

            if (options.maxLength && fileList.length > options.maxLength) {
                limitResult.status = 2;
                limitResult.errorMsg = options.maxLengthError || ("最多可选择" + options.maxLength + "个文件");
            } else if (errorSizeFile) {
                limitResult.status = 2;
                limitResult.errorMsg = options.maxSizeError || ("所选文件最大支持" + (options.maxSize >> 10) + "k");
                limitResult.nonsupportFiles = errorSizeFile;
            } else if (errorSuffixFile) {
                limitResult.status = 2;
                limitResult.errorMsg = options.suffixError || (options.multiple ? "包含不支持的文件类型" : "不支持的文件类型");
                limitResult.nonsupportFiles = errorSuffixFile;
            }

            return limitResult;
        }

        function getInputNode(options) {
            var inputNode = document.getElementById("frequently_select_file_ipt_id");
            if (inputNode) {
                inputNode.removeEventListener('change', onChange);
                document.body.removeChild(inputNode);
                inputNode = null;
            }
            inputNode = document.createElement("input");
            inputNode.id = "frequently_select_file_ipt_id";
            inputNode.name = Date.now() + 'file';
            inputNode.type = "file";
            if (options.multiple) {
                inputNode.multiple = 'multiple';
            }
            inputNode.style = "display: none;"
            inputNode.addEventListener('change', onChange);
            document.body.appendChild(inputNode);
            return inputNode;
        }
    },

    // 文件上传
    uploadFileAjax: function (options) {
        $.ajax({
            type: "POST",
            url: options.url,
            data: options.formData,
            dataType: "json",
            processData: false,  // 不处理数据
            contentType: false, // 不设置内容类型
            success: function (res) {
                options.success && options.success(res)
            },
            error: function (jqXhr, textStatus, errorThrown) {
                options.error && options.error.apply(this, arguments);
            }
        });
    },

    // 获取URL参数
    getUrlParams: function () {
        var optionsStr = location.search;
        var options = {};
        if (optionsStr) {
            optionsStr = optionsStr.split('?')[1] || '';
            var optionsArr = optionsStr.split('&');
            for (var i = 0; i < optionsArr.length; i++) {
                var optionArr = optionsArr[i].split('=');
                optionArr[0] && (options[optionArr[0].trim()] = (optionArr[1] || '').trim());
            }
        }
        return options;
    },

    // 删除URL参数
    deleteUrlParams: function (params) {
        var pathname = location.pathname, deleteNameArr = [];
        if (Object.prototype.toString.call(params) === '[object Object]') {
            deleteNameArr = Object.keys(params);
        } else if (typeof params === 'string') {
            deleteNameArr.push(params);
        } else if (Object.prototype.toString.call(params) === '[object Array]') {
            deleteNameArr = params;
        }

        if (deleteNameArr.length > 0) {
            var options = FrequentlyUtils.getUrlParams();
            for (var i = 0; i < deleteNameArr.length; i++) {
                delete options[deleteNameArr[i]];
            }

            pathname += "?";
            var okeys = Object.keys(options);
            for (var i = 0; i < okeys.length; i++) {
                pathname += ((i === 0 ? "" : "&") + okeys[i] + "=" + options[okeys[i]]);
            }
        }

        history.replaceState(null, "", pathname);
    },

    // 添加URL参数
    addUrlParams: function (obj) {
        if (Object.prototype.toString.call(obj) === '[object Object]') {
            var pathname = location.pathname;
            var options = Object.assign({}, FrequentlyUtils.getUrlParams(), obj);

            pathname += "?";
            var okeys = Object.keys(options);
            for (var i = 0; i < okeys.length; i++) {
                pathname += ((i === 0 ? "" : "&") + okeys[i] + "=" + options[okeys[i]]);
            }

            history.replaceState(null, "", pathname);
        }
    },

    // a标签下载文件
    turnByANode: function (href, target) {
        var aNode = document.createElement("a");
        aNode.href = href;
        aNode.target = target || "_self";
        document.body.appendChild(aNode);
        aNode.click();
        document.body.removeChild(aNode);
    }


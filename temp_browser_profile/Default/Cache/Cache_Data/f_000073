function getContent(id, page, type) {
    msg_list_loading = true;
    $.ajax({
        type: 'POST',
        url: getContentUrl,
        dataType: "json",
        data: {
            page: page,
            perpage: 10,
            category_id: id
        },
        success: function (data) {
            msg_list_loading = false;
            if (type == 'switch') {
                $('.new').empty();
                initList(data.data, 'add');
            } else if (type == 'add') {
                if (data.data.length) {
                    initList(data.data, 'add');
                }
            } else {
                initList(data.data);
            }
            flag = data.data.length > 0;
        },
        error: function () {
            msg_list_loading = false;
            // alert("error");
        }
    })
}
function switchBar(is, id) {
    $(is).addClass('active').siblings().removeClass('active');
    page = 1;
    msg_list_loading = false;
    dataType = id;
    $(".new").scrollTop(0);
    getContent(id, 1, 'switch');
}
function initList(data, type) {
    layui.use(['jquery', 'laytpl'], function () {
        var laytpl = layui.laytpl;

        if (page == 1 && data && data.length > 0) {
            var firstItemArr = data.splice(0, 1);
            var resultSingle = laytpl($('#list').html()).render({ data: firstItemArr });
            $('.single-new').html(resultSingle);
        }

        var result = laytpl($('#list').html()).render({ data: data });
        if (type == 'add') {
            return $('.new').append(result);
        }
    })
}

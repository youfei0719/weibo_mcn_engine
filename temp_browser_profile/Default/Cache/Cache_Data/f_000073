        scrollbar: {
            el: '.flow-red-grass-swiper-scrollbar',
            // dragSize: 100 / $(".index-banner-wrap .swiper-slide").length,
            dragSize: 100 / Number(banner_data_count || 0),
        },// 滚动条
    });
    var prevNode = $(".flow-red-grass-swiper-prev");
    var nextNode = $(".flow-red-grass-swiper-next");
    if (banner_data_count < 2) {
        prevNode.hide();
        nextNode.hide();
        $(".flow-red-grass-swiper-scrollbar").hide();
    }
    $('#bannerWrap').mouseenter(function () {
        mySwiper.autoplay.stop();
        if (banner_data_count > 1) {
            prevNode.css("left", "10px");
            nextNode.css("right", "10px");
        }
    }).mouseleave(function () {
        mySwiper.autoplay.start();
        if (banner_data_count > 1) {
            prevNode.css("left", "-50px");
            nextNode.css("right", "-50px");
        }
    })
}

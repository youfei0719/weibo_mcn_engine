$(".card-main").on("click", ".recommend-account-item .capsule-wrap .add-cart", function () {
    var plattype = $(this).data("plattype");
    var mediaid = $(this).data("id");
    var requestUrl = "", targetUrl = "";
    if (plattype == 3) { // douyin
        requestUrl = douyin_checkbox;
        targetUrl = douyin_mediauser;
    } else if (plattype == 2) { // weibo
        requestUrl = weibo_checkbox;
        targetUrl = weibo_mediauser;
        setTrackCode(20110)
    } else { // redbook
        requestUrl = redbook_checkbox;
        targetUrl = redbook_mediauser;
    }

    $.ajax({
        type: "POST",
        url: requestUrl,
        data: { mediaid: mediaid },
        dataType: "JSON",
        success: function (ret) {
            if (ret.err == 200) {
                window.location.href = targetUrl;
            } else if (ret.err > 50000 && ret.err < 50100){ // 禁止下单 弹窗提示
                stopDownOrderDialog();
            } else {
                layer.msg('投放失败！');
            }
        },
        error: function () {
            layer.msg("网络异常，请稍后重试");
        }
    });
})

// 关注
var followFlag = false;// 防止重复提交
$(".card-main").on("click", ".recommend-account-item .capsule-wrap .add-favor", function () {
    if (followFlag) return;
    followFlag = true;

    var _this = $(this);
    var plattype = _this.data("plattype");
    var mediaid = _this.data("id");
    var account_uid = _this.data("uid");
    var type = _this.data("type");
    var requestUrl = "", requestParams;
    if (plattype == 3) { // douyin
        requestUrl = douyin_enshrineurl;
        requestParams = { mediaid: mediaid, account_uid: account_uid, type: type == 1 ? 2 : 1 };
    } else if (plattype == 2) { // weibo
        requestUrl = type == 0 ? weibo_enshrineurl : weibo_noenshrineurl;
        requestParams = { mediaid: mediaid, account_uid: account_uid, platform: "weibo" };
    } else { // redbook
        requestUrl = redbook_enshrineurl;
        requestParams = { mediaid: mediaid, account_uid: account_uid, type: type == 1 ? 2 : 1 };
    }

    $.ajax({
        type: "POST",
        url: requestUrl,
        data: requestParams,
        dataType: "JSON",
        success: function (ret) {
            followFlag = false;

            if ((plattype == 2 && ret.err==0) || (plattype != 2 && ret.err==200)) {
                if (type == 0) {
                    !_this.hasClass("active") && _this.addClass("active").data("type", 1);
                    layer.msg(new_order_process == 1 ? '已关注红人</br> 可在红人资源池中查看已关注红人' : '收藏成功，可前往“只看收藏”查看！');
                } else {
                    _this.hasClass("active") && _this.removeClass("active").data("type", 0);
                    layer.msg(new_order_process == 1 ? '已取消关注</br> 该红人信息已从红人资源池中移除' : '取消收藏成功！');
                }

                if (plattype == 3) { // douyin
                    if (obj.douyin && obj.douyin.length > 0) {
                        for (var i = 0; i < obj.douyin.length; i++) {
                            if (obj.douyin[i].media_id == mediaid) {
                                obj.douyin[i].ad_followed = (type == 0 ? 1 : 0);
                                break;
                            }
                        }
                    }
                    if (douyinList && douyinList.length > 0) {
                        for (var i = 0, j, index = -1; i < douyinList.length; i++) {
                            for (j = 0; j < douyinList[i].length; j++) {
                                if (douyinList[i][j].media_id == mediaid) {
                                    douyinList[i][j].ad_followed = (type == 0 ? 1 : 0);
                                    index = j;
                                    break;
                                }
                            }
                            if (index != -1) break;
                        }
                    }
                } else if (plattype == 2) { // weibo
                    if (obj.weibo && obj.weibo.length > 0) {
                        for (var i = 0; i < obj.weibo.length; i++) {
                            if (obj.weibo[i].media_id == mediaid) {
                                obj.weibo[i].ad_followed = (type == 0 ? 1 : 0);
                                break;
                            }
                        }
                    }
                } else { // redbook
                    if (obj.redbook && obj.redbook.length > 0) {
                        for (var i = 0; i < obj.redbook.length; i++) {
                            if (obj.redbook[i].media_id == mediaid) {
                                obj.redbook[i].ad_followed = (type == 0 ? 1 : 0);
                                break;
                            }
                        }
                    }
                }
            } else {
                layer.msg(ret.msg);
            }
        },
        error: function () {
            followFlag = false;
            layer.msg("网络异常，请稍后重试");
        }

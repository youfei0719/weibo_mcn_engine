var all_page_index = 0;
var all_max_page_length = 0;
function syncPagination (type) {
    if (type === "all") {
        if (all_page_index == 0) {
            $(".pagination-wrap.page-all-anchor").find(".last").removeClass("disabled").addClass("disabled");
        } else {
            $(".pagination-wrap.page-all-anchor").find(".last").removeClass("disabled");
        }
        if (all_page_index == all_max_page_length - 1) {
            $(".pagination-wrap.page-all-anchor").find(".next").removeClass("disabled").addClass("disabled");
        } else {
            $(".pagination-wrap.page-all-anchor").find(".next").removeClass("disabled");
        }
        $(".pagination-wrap.page-all-anchor").find(".count-wrap .page").html(all_page_index + 1);
        $(".pagination-wrap.page-all-anchor").find(".count-wrap .total-page").html(all_max_page_length);
        if (all_max_page_length > 0) {
            $(".pagination-wrap.page-all-anchor").css("display", "flex");
        }
    } else if (type === "douyinAll") {
        if (d_page == 0) {
            $(".pagination-wrap.page-douyin-anchor").find(".last").removeClass("disabled").addClass("disabled");
        } else {
            $(".pagination-wrap.page-douyin-anchor").find(".last").removeClass("disabled");
        }
        if (d_page == douyinList.length - 1) {
            $(".pagination-wrap.page-douyin-anchor").find(".next").removeClass("disabled").addClass("disabled");
        } else {
            $(".pagination-wrap.page-douyin-anchor").find(".next").removeClass("disabled");
        }
        $(".pagination-wrap.page-douyin-anchor").find(".count-wrap .page").html(d_page + 1);
        $(".pagination-wrap.page-douyin-anchor").find(".count-wrap .total-page").html(douyinList.length);
        if (douyinList.length > 0) {
            $(".pagination-wrap.page-douyin-anchor").css("display", "flex");
        }
    }
}
$(".pagination-wrap").find(".btn").click(function () {
    var type = $(this).data("type");
    var tag = $(this).data("tag");
    if (tag == 1) { // all
        if (type === "last") {
            if (all_page_index <= 0) {
                all_page_index = 0;
                return false;
            } else {
                all_page_index--;
            }
        } else if (type === "next") {
            if (all_page_index >= all_max_page_length - 1) {
                all_page_index = all_max_page_length - 1;
                return false;
            } else {
                all_page_index++;
            }
        }
        a_apge_w = (all_page_index % obj.weibo.length);
        a_apge_d = (all_page_index % obj.weibo1.length);
        // a_apge_d = (all_page_index % obj.douyin.length);
        a_apge_r = (all_page_index % obj.redbook.length);
        $('.all').empty();
        for (var key in obj) {
            initTpl(key);
        }
        syncPagination("all");
    } else if (tag == 0) { // douyin
        if (type === "last") {
            if (d_page <= 0) {
                d_page = 0;
                return false;
            } else {
                d_page--;
            }
        } else if (type === "next") {
            if (d_page >= douyinList.length - 1) {
                d_page = douyinList.length - 1;
                return false;
            } else {
                d_page++;
            }
        }
        initTpl('douyinAll');
        syncPagination("douyinAll");
    }
})
